PORT=3006
# Replace with your actual absolute path to the .mdb/.accdb file
LEGACY_DB_PATH=C:\Path\To\Your\Database.mdb
LEGACY_DB_PASSWORD=

# Shared secret. El bridge se niega a arrancar si está vacío.
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Debe coincidir EXACTAMENTE con LEGACY_BRIDGE_TOKEN del back (apps/core/.env).
LEGACY_BRIDGE_TOKEN=replace_with_64_char_random_hex

# Master switch de escrituras. Si false, ningún UPDATE/INSERT/DELETE pasa, ni con allowWrite=true.
LEGACY_WRITES_ENABLED=false
