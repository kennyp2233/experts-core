# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api
LOG_LEVEL=debug

# JWT
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRES_IN=15m

# Refresh Token
REFRESH_TOKEN_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Database URL (single database for all schemas)
DATABASE_URL=postgresql://postgres:password@localhost:5432/experts_core

# Database Schema URLs (Dynamic schema selection)
DATABASE_URL_DATOS_MAESTROS="postgresql://postgres:password@localhost:5432/experts_core?schema=datos_maestros"
DATABASE_URL_USUARIOS="postgresql://postgres:password@localhost:5432/experts_core?schema=usuarios"
DATABASE_URL_DOCUMENTOS="postgresql://postgres:password@localhost:5432/experts_core?schema=documentos"
DATABASE_URL_GUIAS="postgresql://postgres:password@localhost:5432/experts_core?schema=guias"
DATABASE_URL_TEMPLATES="postgresql://postgres:password@localhost:5432/experts_core?schema=templates"

# FITO Module Configuration
# Path to the Microsoft Access Database (.accdb)
# Windows Example: C:\path\to\database.accdb
# Linux/Docker Example (if mounted): /app/storage/legacy.accdb
LEGACY_DB_PATH="C:\path\to\database.accdb"

# Bridge a Access (legacy-bridge corre en el host, fuera de Docker)
ACCESS_BRIDGE_URL=http://host.docker.internal:3006/query
# Para dev local sin docker, usar: http://localhost:3006/query

# Shared secret con el bridge. Debe coincidir con LEGACY_BRIDGE_TOKEN de legacy-bridge/.env.
LEGACY_BRIDGE_TOKEN=replace_with_64_char_random_hex

# EBF Portal (integrations/ebf-portal) — credenciales del usuario de servicio
EBF_PORTAL_USER=manager@expertshcargo.com
EBF_PORTAL_PASS=replace_with_real_password
EBF_PORTAL_BASE_URL=https://portal.ebfcargo.com
